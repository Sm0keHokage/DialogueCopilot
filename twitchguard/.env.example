# Секреты TwitchGuard — только из окружения (IR-26). Никогда не коммитьте .env.

# Из Twitch Developer Console (https://dev.twitch.tv/console/apps)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Должен в точности совпадать с Redirect URI приложения в Dev Console
TWITCH_REDIRECT_URI=http://localhost:5173/auth/twitch/callback

# Ключ шифрования токенов/API-ключей (Fernet). Сгенерировать:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Подпись session-cookie
SESSION_SECRET=

# Переопределяются docker-compose'ом; нужны при запуске без Docker
DATABASE_URL=postgresql+asyncpg://twitchguard:twitchguard@localhost:5432/twitchguard
REDIS_URL=redis://localhost:6379/0

# Почта для подтверждения аккаунтов личного кабинета.
# Пусто (по умолчанию) = dev-режим: письмо не отправляется, ссылка
# подтверждения пишется в лог backend'а.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=TwitchGuard <no-reply@example.com>
SMTP_STARTTLS=true
# База для ссылок в письмах (по умолчанию = FRONTEND_ORIGIN)
PUBLIC_BASE_URL=
